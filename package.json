{
  "name": "tech-threads",
  "version": "1.0.0",
  "description": "Um projeto pra eu estudar juntinho com o Filipe Deschamps",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm services:up && pnpm migration:up && next dev",
    "lint:check": "next lint --dir .",
    "lint:fix": "next lint --fix --dir .",
    "type-check": "tsc --noEmit",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "validate": "pnpm type-check && pnpm format:check && pnpm lint:check",
    "test:dev": "concurrently -k -s command-test -c cyan.bold,green.bold -n server,test 'pnpm --silent dev' 'pnpm test:raw'",
    "test:watch": "concurrently -k -c cyan.bold,magenta.bold -n server,test 'pnpm dev' 'pnpm test:raw --watch'",
    "test:raw": "./scripts/wait-for.sh localhost 3000 15 && pnpm jest --runInBand",
    "services:up": "docker compose -f infra/compose.yaml up -d --wait",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "migration:create": "node-pg-migrate -m infra/migrations create",
    "migration:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "prepare": "husky"
  },
  "author": "@henriquenas",
  "license": "MIT",
  "dependencies": {
    "dotenv": "16.6.1",
    "dotenv-expand": "12.0.3",
    "next": "14.2.35",
    "node-pg-migrate": "7.9.1",
    "pg": "8.20.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@jest/globals": "29.7.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "29.5.14",
    "@types/node": "20.6.2",
    "@types/pg": "8.20.0",
    "@types/react": "18.2.21",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "concurrently": "9.2.1",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-testing-library": "7.16.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "postcss": "8.5.12",
    "prettier": "2.8.8",
    "tailwindcss": "3.4.19",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.2.2"
  },
  "peerDependencies": {
    "typescript": "5.0.0"
  }
}
